# Panaudia — example environment file
#
# Copy to `.env` (`cp .env.example .env`) and uncomment what you want to override.
# The server loads `.env` automatically at startup IF it exists; a missing file
# is fine. Real environment variables ALWAYS win over values in this file, and
# anything left unset falls back to the default shown below.
#
# Full reference: docs/environment-variables.md
#
# Note: PANAUDIA_ENV_FILE (which selects this file's path) must be a real
# environment variable — setting it inside the file itself has no effect.
# Booleans are integers: 1 = on, 0 = off.

# --- Network & transport ---
#PANAUDIA_HOST=0.0.0.0
#PANAUDIA_PORT=4443
#PANAUDIA_ICE_HOST=
#PANAUDIA_ICE_PORT=0

# --- TLS & authentication ---
#PANAUDIA_TLS_CTR_PATH=keys/server.crt
#PANAUDIA_TLS_KEY_PATH=keys/server.key
#PANAUDIA_TICKET_KEY_PATH=keys/panaudia_key.pub
#PANAUDIA_UNTICKETED=1

# --- Spatial & rendering ---
#PANAUDIA_SPACE_SIZE=40
#PANAUDIA_SPACE_ORDER=3
#PANAUDIA_SPACE_MAX_SOURCES=128
#PANAUDIA_REVERB_PRESET=0

# --- Panaudia Link (ROC) — opt-in, off by default ---
#PANAUDIA_ENABLE_LINK_IN=0
#PANAUDIA_ENABLE_LINK_OUT=0
#PANAUDIA_LINK_PORT=80

# --- Runtime & performance ---
#PANAUDIA_GOMAXPROCS=4

# --- State-cache tuning (rarely changed; applied only when > 0) ---
#PANAUDIA_CACHE_RING_SIZE=16
#PANAUDIA_CACHE_SEGMENT_CAPACITY=128
#PANAUDIA_CACHE_TOMBSTONE_TTL_SEC=30

# --- Logging & diagnostics ---
#PANAUDIA_LOG_LEVEL=2
#PANAUDIA_LOG_MS=0
#QLOGDIR=

# --- Test & load-generation fixtures (synthetic nodes; output discarded) ---
#PANAUDIA_TEST_TONE=0
#PANAUDIA_TEST_PEOPLE=0
#PANAUDIA_TEST_VOICES=0
#PANAUDIA_STEREO_TEST=0

# --- Related (dependency-controlled) ---
#MOQ_LOG_LEVEL=
